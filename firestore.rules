rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function isDimigoAccount() {
      return signedIn() && email().matches('.*@dimigo[.]hs[.]kr$');
    }

    function adminPath(targetEmail) {
      return /databases/$(database)/documents/adminUsers/$(targetEmail);
    }

    function isBootstrapAdmin() {
      return signedIn() && email() in ['hwanwook100510@gmail.com'];
    }

    function isAdmin() {
      return isBootstrapAdmin() || (signedIn() && exists(adminPath(email())));
    }

    function isAllowedAccount() {
      return isDimigoAccount() || isAdmin();
    }

    function isStudent() {
      return isDimigoAccount() && !isAdmin();
    }

    function isSelfEmail(targetEmail) {
      return signedIn() && email() == targetEmail;
    }

    function assignmentPath(targetEmail) {
      return /databases/$(database)/documents/clubRoleAssignments/$(targetEmail);
    }

    function applicationPath(targetEmail) {
      return /databases/$(database)/documents/clubApplications/$(targetEmail);
    }

    function currentAssignment() {
      return get(assignmentPath(email())).data;
    }

    function isClubLeader(club) {
      return isAllowedAccount()
        && exists(assignmentPath(email()))
        && currentAssignment().club == club
        && currentAssignment().role == '동아리장';
    }

    function choseClub(application, club) {
      return application.firstChoice == club
        || application.secondChoice == club
        || application.thirdChoice == club;
    }

    function hasAppliedToClub(targetEmail, club) {
      return exists(applicationPath(targetEmail))
        && choseClub(get(applicationPath(targetEmail)).data, club);
    }

    function isRequestTime(value) {
      return value is timestamp && value == request.time;
    }

    function validProfile(data, targetEmail) {
      return data.keys().hasOnly(['email', 'name', 'grade', 'classNumber', 'number', 'createdAt'])
        && data.email is string
        && data.name is string
        && data.grade is string
        && data.classNumber is string
        && data.number is string
        && data.createdAt is timestamp
        && data.email == targetEmail
        && data.name.size() > 0
        && data.name.size() <= 20
        && data.grade in ['1', '2', '3']
        && data.classNumber.matches('[0-9]{1,2}')
        && data.number.matches('[0-9]{1,2}');
    }

    function validApplication(data, targetEmail) {
      return data.keys().hasOnly(['id', 'email', 'name', 'grade', 'classNumber', 'number', 'firstChoice', 'secondChoice', 'thirdChoice', 'questionAnswers', 'createdAt', 'locked', 'unlockedByAdmin'])
        && data.id is string
        && data.email is string
        && data.name is string
        && data.grade is string
        && data.classNumber is string
        && data.number is string
        && data.firstChoice is string
        && data.secondChoice is string
        && data.thirdChoice is string
        && data.createdAt is timestamp
        && data.locked is bool
        && data.unlockedByAdmin is bool
        && data.id == targetEmail
        && data.email == targetEmail
        && data.name.size() > 0
        && data.name.size() <= 20
        && data.grade in ['1', '2', '3']
        && data.classNumber.matches('[0-9]{1,2}')
        && data.number.matches('[0-9]{1,2}')
        && data.firstChoice.size() > 0
        && data.firstChoice.size() <= 30
        && data.secondChoice.size() > 0
        && data.secondChoice.size() <= 30
        && data.thirdChoice.size() > 0
        && data.thirdChoice.size() <= 30
        && (!('questionAnswers' in data) || (data.questionAnswers is list && data.questionAnswers.size() <= 3))
        && data.firstChoice != data.secondChoice
        && data.firstChoice != data.thirdChoice
        && data.secondChoice != data.thirdChoice;
    }

    function validUserApplicationCreate(data, targetEmail) {
      return validApplication(data, targetEmail)
        && isRequestTime(data.createdAt)
        && data.locked == true
        && data.unlockedByAdmin == false;
    }

    function validUserApplicationUpdate(data, targetEmail) {
      return validApplication(data, targetEmail)
        && data.createdAt == resource.data.createdAt
        && data.locked == true
        && data.unlockedByAdmin == false;
    }

    function validAssignment(data, targetEmail) {
      return data.keys().hasOnly(['email', 'club', 'role', 'updatedAt'])
        && data.email is string
        && data.email == targetEmail
        && data.club is string
        && data.role in ['동아리원', '동아리장']
        && data.updatedAt is timestamp
        && data.club.size() > 0
        && data.club.size() <= 30
        && isRequestTime(data.updatedAt);
    }

    function validLeaderAssignedMember(data, targetEmail) {
      return validAssignment(data, targetEmail)
        && data.role == '동아리원'
        && isClubLeader(data.club)
        && hasAppliedToClub(targetEmail, data.club);
    }

    function validIntro(data, club) {
      return data.keys().hasOnly(['club', 'intro', 'updatedAt'])
        && data.club == club
        && data.intro is string
        && data.updatedAt is timestamp
        && data.intro.size() <= 1500
        && isRequestTime(data.updatedAt);
    }

    function validSuggestion(data, suggestionId) {
      return data.keys().hasOnly(['id', 'title', 'category', 'content', 'effect', 'createdAt', 'isAnonymous'])
        && data.id is string
        && data.id == suggestionId
        && data.title is string
        && data.category is string
        && data.content is string
        && data.effect is string
        && data.createdAt is timestamp
        && data.isAnonymous is bool
        && data.title.size() > 0
        && data.title.size() <= 80
        && data.category.size() > 0
        && data.category.size() <= 20
        && data.content.size() > 0
        && data.content.size() <= 1000
        && data.effect.size() > 0
        && data.effect.size() <= 500;
    }

    function validSuggestionCreate(data, suggestionId) {
      return validSuggestion(data, suggestionId) && isRequestTime(data.createdAt);
    }

    function validSuggestionAuthor(data, suggestionId) {
      return data.keys().hasOnly(['suggestionId', 'authorEmail', 'authorName'])
        && data.suggestionId is string
        && data.suggestionId == suggestionId
        && data.authorEmail is string
        && data.authorName is string
        && data.authorEmail == email()
        && data.authorName.size() > 0
        && data.authorName.size() <= 20;
    }

    function validEvaluation(data, targetEmail) {
      return data.keys().hasOnly(['email', 'name', 'createdAt', 'promise', 'communication', 'event', 'reflection'])
        && data.email is string
        && data.name is string
        && data.createdAt is timestamp
        && data.promise is int
        && data.communication is int
        && data.event is int
        && data.reflection is int
        && data.email == targetEmail
        && data.name.size() > 0
        && data.name.size() <= 20
        && data.promise >= 1
        && data.promise <= 5
        && data.communication >= 1
        && data.communication <= 5
        && data.event >= 1
        && data.event <= 5
        && data.reflection >= 1
        && data.reflection <= 5;
    }

    function validEvaluationCreate(data, targetEmail) {
      return validEvaluation(data, targetEmail) && isRequestTime(data.createdAt);
    }

    function validSummary(data) {
      return data.keys().hasOnly(['promise', 'communication', 'event', 'reflection', 'count'])
        && data.promise is number
        && data.communication is number
        && data.event is number
        && data.reflection is number
        && data.count is int
        && data.promise >= 0
        && data.promise <= 5
        && data.communication >= 0
        && data.communication <= 5
        && data.event >= 0
        && data.event <= 5
        && data.reflection >= 0
        && data.reflection <= 5
        && data.count >= 0;
    }

    function validVoteRecord(data, voteId) {
      return data.keys().hasOnly(['id', 'email', 'name', 'target', 'choice', 'createdAt'])
        && data.id is string
        && data.id == voteId
        && data.email is string
        && data.name is string
        && data.target is string
        && data.choice is string
        && data.createdAt is timestamp
        && data.email.size() > 0
        && data.email == email()
        && data.name.size() > 0
        && data.name.size() <= 20
        && data.target.size() > 0
        && data.target.size() <= 80
        && data.choice.size() > 0
        && data.choice.size() <= 80
        && data.id == email() + '_' + data.target;
    }

    function validElectionSetting(data) {
      return data.keys().hasOnly(['isClosed', 'closedAt'])
        && data.isClosed is bool
        && (!('closedAt' in data) || data.closedAt is timestamp);
    }

    function validElectionResult(data) {
      return data.keys().hasOnly(['id', 'isClosed', 'closedAt', 'totalVotes', 'counts', 'percentages', 'winners'])
        && data.id == 'current'
        && data.isClosed == true
        && data.closedAt is timestamp
        && data.totalVotes is int
        && data.counts is map
        && data.percentages is map
        && data.winners is list
        && data.totalVotes >= 0;
    }

    function validPledge(data, pledgeId) {
      return data.keys().hasOnly(['id', 'title', 'description', 'status', 'updatedAt'])
        && data.id is string
        && data.id == pledgeId
        && data.title is string
        && data.description is string
        && data.status == '선거 중'
        && data.updatedAt is timestamp
        && data.title.size() > 0
        && data.title.size() <= 100
        && data.description.size() > 0
        && data.description.size() <= 1000;
    }

    function validSuspension(data, targetEmail) {
      return data.keys().hasOnly(['email', 'suspendedAt', 'suspendedBy'])
        && data.email is string
        && data.suspendedAt is timestamp
        && data.suspendedBy is string
        && data.email == targetEmail
        && data.suspendedBy == email()
        && isRequestTime(data.suspendedAt);
    }

    match /studentProfiles/{targetEmail} {
      allow get: if isAdmin() || (isAllowedAccount() && isSelfEmail(targetEmail));
      allow list: if isAdmin();
      allow create: if isAllowedAccount()
        && isSelfEmail(targetEmail)
        && validProfile(request.resource.data, targetEmail)
        && isRequestTime(request.resource.data.createdAt);
      allow update: if isAdmin() && validProfile(request.resource.data, targetEmail);
      allow delete: if false;
    }

    match /clubApplications/{targetEmail} {
      allow get: if isAdmin()
        || (isAllowedAccount() && isSelfEmail(targetEmail))
        || isClubLeader(resource.data.firstChoice)
        || isClubLeader(resource.data.secondChoice)
        || isClubLeader(resource.data.thirdChoice);
      allow list: if isAdmin()
        || isClubLeader(resource.data.firstChoice)
        || isClubLeader(resource.data.secondChoice)
        || isClubLeader(resource.data.thirdChoice);
      allow create: if isAllowedAccount()
        && isSelfEmail(targetEmail)
        && validUserApplicationCreate(request.resource.data, targetEmail);
      allow update: if isAllowedAccount()
        && isSelfEmail(targetEmail)
        && resource.data.unlockedByAdmin == true
        && validUserApplicationUpdate(request.resource.data, targetEmail);
      allow create: if isAdmin()
        && validApplication(request.resource.data, targetEmail)
        && isRequestTime(request.resource.data.createdAt);
      allow update: if isAdmin()
        && validApplication(request.resource.data, targetEmail)
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /clubRoleAssignments/{targetEmail} {
      allow get: if isAdmin() || (isAllowedAccount() && isSelfEmail(targetEmail));
      allow list, delete: if isAdmin();
      allow create, update: if isAdmin() && validAssignment(request.resource.data, targetEmail);
      allow create, update: if validLeaderAssignedMember(request.resource.data, targetEmail);
    }

    match /clubIntros/{club} {
      allow get, list: if true;
      allow create, update: if (isAdmin() || isClubLeader(club))
        && validIntro(request.resource.data, club);
      allow delete: if isAdmin();
    }

    match /policySuggestions/{suggestionId} {
      allow get, list: if true;
      allow create: if isStudent() && validSuggestionCreate(request.resource.data, suggestionId);
      allow update: if isAdmin()
        && validSuggestion(request.resource.data, suggestionId)
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /policySuggestionAuthors/{suggestionId} {
      allow get, list: if isAdmin();
      allow create: if isStudent() && validSuggestionAuthor(request.resource.data, suggestionId);
      allow update, delete: if isAdmin();
    }

    match /evaluationResponses/{targetEmail} {
      allow get: if isAdmin() || (isStudent() && isSelfEmail(targetEmail));
      allow list: if isAdmin();
      allow create: if isStudent()
        && isSelfEmail(targetEmail)
        && !exists(/databases/$(database)/documents/evaluationResponses/$(targetEmail))
        && validEvaluationCreate(request.resource.data, targetEmail);
      allow update: if false;
      allow delete: if false;
    }

    match /voteRecords/{voteId} {
      allow get: if isAdmin()
        || (isStudent() && (!exists(/databases/$(database)/documents/voteRecords/$(voteId)) || resource.data.email == email()));
      allow list: if isAdmin();
      allow create: if isStudent()
        && validVoteRecord(request.resource.data, voteId)
        && isRequestTime(request.resource.data.createdAt)
        && !exists(/databases/$(database)/documents/voteRecords/$(voteId))
        && (!exists(/databases/$(database)/documents/electionSettings/current) || get(/databases/$(database)/documents/electionSettings/current).data.isClosed != true);
      allow update, delete: if false;
    }

    match /electionSettings/{settingId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && settingId == 'current' && validElectionSetting(request.resource.data);
      allow delete: if isAdmin();
    }

    match /electionResults/{resultId} {
      allow get, list: if isAdmin() || (exists(/databases/$(database)/documents/electionSettings/current) && get(/databases/$(database)/documents/electionSettings/current).data.isClosed == true);
      allow create, update: if isAdmin() && resultId == 'current' && validElectionResult(request.resource.data);
      allow delete: if isAdmin();
    }

    match /pledgeProgress/{pledgeId} {
      allow get, list: if true;
      allow create, update: if isAdmin()
        && validPledge(request.resource.data, pledgeId)
        && isRequestTime(request.resource.data.updatedAt);
      allow delete: if isAdmin();
    }

    match /publicStats/{statId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && statId == 'evaluationSummary' && validSummary(request.resource.data);
      allow delete: if isAdmin();
    }

    match /suspendedUsers/{targetEmail} {
      allow get: if isAdmin() || (signedIn() && isSelfEmail(targetEmail));
      allow list, delete: if isAdmin();
      allow create, update: if isAdmin()
        && !isSelfEmail(targetEmail)
        && validSuspension(request.resource.data, targetEmail);
    }

    match /adminUsers/{targetEmail} {
      allow get: if isBootstrapAdmin() || (isAdmin() && isSelfEmail(targetEmail));
      allow list, create, update, delete: if isBootstrapAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
