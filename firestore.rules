rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isDimigoAccount() {
      return signedIn() && request.auth.token.email.matches('.*@dimigo[.]hs[.]kr$');
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email in ['hwanwook100510@gmail.com'];
    }

    function isAllowedAccount() {
      return isDimigoAccount() || isAdmin();
    }

    function isSelfEmail(email) {
      return signedIn() && request.auth.token.email == email;
    }

    function assignmentPath(email) {
      return /databases/$(database)/documents/clubRoleAssignments/$(email);
    }

    function isClubMember(club) {
      return isAllowedAccount()
        && exists(assignmentPath(request.auth.token.email))
        && get(assignmentPath(request.auth.token.email)).data.club == club;
    }

    function isClubLeader(club) {
      return isClubMember(club)
        && get(assignmentPath(request.auth.token.email)).data.role == '동아리장';
    }

    function validProfile(data, email) {
      return data.keys().hasOnly(['email', 'name', 'grade', 'classNumber', 'number', 'createdAt'])
        && data.email is string
        && data.name is string
        && data.grade is string
        && data.classNumber is string
        && data.number is string
        && data.createdAt is string
        && data.email == email
        && data.name.size() > 0
        && data.name.size() <= 20
        && data.grade in ['1', '2', '3']
        && data.classNumber.matches('[0-9]{1,2}')
        && data.number.matches('[0-9]{1,2}')
        && data.createdAt.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}');
    }

    function validApplication(data, email) {
      return data.keys().hasOnly(['id', 'email', 'name', 'grade', 'classNumber', 'number', 'firstChoice', 'secondChoice', 'thirdChoice', 'createdAt', 'locked', 'unlockedByAdmin'])
        && data.id is number
        && data.email is string
        && data.name is string
        && data.grade is string
        && data.classNumber is string
        && data.number is string
        && data.firstChoice is string
        && data.secondChoice is string
        && data.thirdChoice is string
        && data.createdAt is string
        && data.locked is bool
        && data.unlockedByAdmin is bool
        && data.email == email
        && data.name.size() > 0
        && data.name.size() <= 20
        && data.grade in ['1', '2', '3']
        && data.classNumber.matches('[0-9]{1,2}')
        && data.number.matches('[0-9]{1,2}')
        && data.firstChoice.size() > 0
        && data.firstChoice.size() <= 30
        && data.secondChoice.size() > 0
        && data.secondChoice.size() <= 30
        && data.thirdChoice.size() > 0
        && data.thirdChoice.size() <= 30
        && data.firstChoice != data.secondChoice
        && data.firstChoice != data.thirdChoice
        && data.secondChoice != data.thirdChoice
        && data.createdAt.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}');
    }

    function validUserApplication(data, email) {
      return validApplication(data, email)
        && data.locked == true
        && data.unlockedByAdmin == false;
    }

    function validAssignment(data, email) {
      return data.keys().hasOnly(['email', 'club', 'role', 'updatedAt'])
        && data.email is string
        && data.email == email
        && data.club is string
        && data.role in ['동아리원', '동아리장']
        && data.updatedAt is string
        && data.club.size() > 0
        && data.club.size() <= 30
        && data.updatedAt.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}');
    }

    function validIntro(data, club) {
      return data.keys().hasOnly(['club', 'intro', 'updatedAt'])
        && data.club == club
        && data.intro is string
        && data.updatedAt is string
        && data.intro.size() <= 1500
        && data.updatedAt.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}');
    }

    function validSuggestion(data) {
      return data.keys().hasOnly(['id', 'title', 'category', 'content', 'effect', 'createdAt', 'isAnonymous'])
        && data.id is number
        && data.title is string
        && data.category is string
        && data.content is string
        && data.effect is string
        && data.createdAt is string
        && data.isAnonymous is bool
        && data.title.size() > 0
        && data.title.size() <= 80
        && data.category.size() > 0
        && data.category.size() <= 20
        && data.content.size() > 0
        && data.content.size() <= 1000
        && data.effect.size() > 0
        && data.effect.size() <= 500
        && data.createdAt.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}');
    }

    function validSuggestionAuthor(data) {
      return data.keys().hasOnly(['suggestionId', 'authorEmail', 'authorName'])
        && data.suggestionId is number
        && data.authorEmail is string
        && data.authorName is string
        && data.authorEmail == request.auth.token.email
        && data.authorName.size() > 0
        && data.authorName.size() <= 20;
    }

    function validEvaluation(data, email) {
      return data.keys().hasOnly(['email', 'name', 'createdAt', 'promise', 'communication', 'event', 'reflection'])
        && data.email is string
        && data.name is string
        && data.createdAt is string
        && data.promise is number
        && data.communication is number
        && data.event is number
        && data.reflection is number
        && data.email == email
        && data.name.size() > 0
        && data.name.size() <= 20
        && data.createdAt.matches('[0-9]{4}-[0-9]{2}-[0-9]{2}')
        && data.promise >= 0
        && data.promise <= 100
        && data.communication >= 0
        && data.communication <= 100
        && data.event >= 0
        && data.event <= 100
        && data.reflection >= 0
        && data.reflection <= 100;
    }

    function validSummary(data) {
      return data.keys().hasOnly(['promise', 'communication', 'event', 'reflection'])
        && data.promise is number
        && data.communication is number
        && data.event is number
        && data.reflection is number
        && data.promise >= 0
        && data.promise <= 100
        && data.communication >= 0
        && data.communication <= 100
        && data.event >= 0
        && data.event <= 100
        && data.reflection >= 0
        && data.reflection <= 100;
    }

    function validSuspension(data, email) {
      return data.keys().hasOnly(['email', 'suspendedAt', 'suspendedBy'])
        && data.email is string
        && data.suspendedAt is string
        && data.suspendedBy is string
        && data.email == email
        && data.suspendedAt.size() <= 40
        && data.suspendedBy == request.auth.token.email;
    }

    match /studentProfiles/{email} {
      allow get: if isAdmin() || (isAllowedAccount() && isSelfEmail(email));
      allow list: if isAdmin();
      allow create: if isAllowedAccount()
        && isSelfEmail(email)
        && validProfile(request.resource.data, email);
      allow create, update: if isAdmin() && validProfile(request.resource.data, email);
      allow delete: if false;
    }

    match /clubApplications/{email} {
      allow get: if isAdmin()
        || (isAllowedAccount() && isSelfEmail(email))
        || isClubMember(resource.data.firstChoice)
        || isClubMember(resource.data.secondChoice)
        || isClubMember(resource.data.thirdChoice);
      allow list: if isAdmin()
        || isClubMember(resource.data.firstChoice)
        || isClubMember(resource.data.secondChoice)
        || isClubMember(resource.data.thirdChoice);
      allow create: if isAllowedAccount()
        && isSelfEmail(email)
        && validUserApplication(request.resource.data, email);
      allow update: if isAllowedAccount()
        && isSelfEmail(email)
        && resource.data.unlockedByAdmin == true
        && validUserApplication(request.resource.data, email);
      allow create, update: if isAdmin() && validApplication(request.resource.data, email);
      allow delete: if false;
    }

    match /clubRoleAssignments/{email} {
      allow get: if isAdmin() || (isAllowedAccount() && isSelfEmail(email));
      allow list, delete: if isAdmin();
      allow create, update: if isAdmin() && validAssignment(request.resource.data, email);
    }

    match /clubIntros/{club} {
      allow get, list: if true;
      allow create, update: if (isAdmin() || isClubLeader(club))
        && validIntro(request.resource.data, club);
      allow delete: if isAdmin();
    }

    match /policySuggestions/{suggestionId} {
      allow get, list: if isAllowedAccount();
      allow create: if isAllowedAccount() && validSuggestion(request.resource.data);
      allow update, delete: if isAdmin() && validSuggestion(request.resource.data);
    }

    match /policySuggestionAuthors/{suggestionId} {
      allow get, list: if isAdmin();
      allow create: if isAllowedAccount() && validSuggestionAuthor(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /evaluationResponses/{email} {
      allow get: if isAdmin() || (isAllowedAccount() && isSelfEmail(email));
      allow list: if isAdmin();
      allow create, update: if isAllowedAccount()
        && isSelfEmail(email)
        && validEvaluation(request.resource.data, email);
      allow delete: if false;
    }

    match /publicStats/{statId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && statId == 'evaluationSummary' && validSummary(request.resource.data);
      allow delete: if isAdmin();
    }

    match /suspendedUsers/{email} {
      allow get: if isAdmin() || (signedIn() && isSelfEmail(email));
      allow list, delete: if isAdmin();
      allow create, update: if isAdmin()
        && !isSelfEmail(email)
        && validSuspension(request.resource.data, email);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
